# ProctorAI Environment Variables
# Copy this file to .env and fill in the actual values

# ════════════════════════════════════════════════════════════════
# BACKEND (.env in /backend directory)
# ════════════════════════════════════════════════════════════════

# Port for Express server
PORT=3000

# Environment (development, production)
NODE_ENV=development

# PostgreSQL connection string
# Format: postgresql://[user[:password]@][netloc][:port][/dbname]
DATABASE_URL=postgresql://postgres@localhost:5432/proctordb

# Session encryption secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=

# Encryption secret for exam answers (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_SECRET=

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# AI Service URL
AI_SERVICE_URL=http://localhost:5000

# HTTPS enabled (false for development, true for production)
HTTPS_ENABLED=false

# ════════════════════════════════════════════════════════════════
# FRONTEND (optional - for development server)
# ════════════════════════════════════════════════════════════════

# API base URL (if not set, frontend will auto-detect based on location.protocol and location.hostname)
# API_BASE_URL=http://localhost:3000/api

# ════════════════════════════════════════════════════════════════
# AI SERVICE (optional - for Python service)
# ════════════════════════════════════════════════════════════════

# AI Service port
AI_PORT=5000

# AI Service debug mode
AI_DEBUG=false
