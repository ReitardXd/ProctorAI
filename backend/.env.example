# Backend Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# Format: postgresql://[user[:password]@][netloc][:port][/dbname][?param1=value1&...]
# Example: postgresql://postgres:password@localhost:5432/proctordb
DATABASE_URL=postgresql://postgres@localhost:5432/proctordb

# Session Management
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_random_session_secret_here

# Encryption for Exam Answers
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=your_random_encryption_secret_here

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# AI Service Configuration
AI_SERVICE_URL=http://localhost:5000

# HTTPS Configuration (set to true when using HTTPS in production)
HTTPS_ENABLED=false
